{
  "name": "@ludylops/video-analysis-core",
  "version": "0.1.0",
  "description": "Shared YouTube video analysis engine (Gemini, yt-dlp) for hosted and companion-package consumers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludmila-omlopes/youtube-video-analyzer.git",
    "directory": "packages/video-analysis-core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "youtube",
    "gemini",
    "video-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.45.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
