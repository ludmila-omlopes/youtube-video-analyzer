GEMINI_API_KEY=your_gemini_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_MODEL=gemini-2.5-pro
YT_DLP_PATH=yt-dlp

# Hosted HTTP loads `.env`, then optional profile overlays, then `.env.local`:
#   OAUTH_ENV_PROFILE=local     → merge `.env.oauth.local` (see npm run dev:hosted:oauth-local)
#   OAUTH_ENV_PROFILE=production → merge `.env.oauth.production` if that file exists
# Keep production-style OAuth values here; put localhost-only overrides in `.env.oauth.local`.
#
# Hosted HTTP auth is protected by default. Configure OAuth for real hosted use,
# or set ALLOW_UNAUTHENTICATED_HOSTED_DEV=true only for local development.
# Cloud-style hosted runtimes default to strict Redis durability. Keep
# CLOUD_DURABILITY_MODE unset locally, or set HOSTED_RUNTIME_ROLE=web|worker|admin
# / CLOUD_DURABILITY_MODE=require_redis explicitly in hosted deployments.
# ALLOW_UNAUTHENTICATED_HOSTED_DEV=false
# HOSTED_RUNTIME_ROLE=web
# CLOUD_DURABILITY_MODE=require_redis
# OAUTH_ENABLED=true
# OAUTH_ISSUER=https://issuer.example.com/
# OAUTH_AUDIENCE=https://your-service.onrender.com/
# OAUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# OAUTH_REQUIRED_SCOPE=mcp:access
# OAUTH_WEB_CLIENT_ID=your_browser_client_id
# OAUTH_WEB_AUTHORIZATION_URL=https://issuer.example.com/authorize
# OAUTH_WEB_TOKEN_URL=https://issuer.example.com/oauth/token
# OAUTH_WEB_REDIRECT_PATH=/oauth/callback
# OAUTH_WEB_SCOPES=openid profile mcp:access
# OAUTH_WEB_AUDIENCE=https://your-service.onrender.com/
# OAUTH_WEB_RESOURCE=https://your-service.onrender.com/
# Optional: confidential client token exchange (omit for pure public/OIDC + PKCE clients)
# OAUTH_WEB_CLIENT_SECRET=
# After login, browser session cookie (also sent to /api/* when using credentials: 'include')
# OAUTH_HOSTED_ACCESS_COOKIE=ya_session
# OAUTH_HOSTED_SESSION_MAX_AGE_SECONDS=28800
# OAUTH_LOGIN_SUCCESS_PATH=/dashboard
# OAUTH_LOGOUT_SUCCESS_PATH=/
# Local dev over HTTP: cookies omit Secure unless you set OAUTH_HOSTED_COOKIE_SECURE=true
# OAUTH_HOSTED_COOKIE_SECURE=false
# If OAUTH_WEB_AUDIENCE / OAUTH_WEB_RESOURCE are omitted, they default to OAUTH_AUDIENCE so the
# authorize URL requests a JWT access token (required for validation). Set explicitly if your IdP differs.
#
# Optional remote session persistence
# SESSION_STORE_DRIVER=redis
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
#
# Admin dashboard
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
#
# Initial credit balance for new remote accounts (HTTP + OAuth)
# REMOTE_ACCOUNT_INITIAL_CREDITS=100
