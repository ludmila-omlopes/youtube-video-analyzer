{
  "name": "@ludylops/youtube-video-analyzer-mcp",
  "mcpName": "io.github.ludmila-omlopes/youtube-video-analyzer",
  "version": "0.2.3",
  "description": "MCP stdio server for analyzing YouTube videos with Google Gemini",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludmila-omlopes/youtube-video-analyzer-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "youtube-video-analyzer-mcp": "bin/youtube-video-analyzer-mcp.js"
  },
  "files": [
    "bin",
    "dist/admin.js",
    "dist/dev",
    "dist/index.js",
    "dist/server.js",
    "dist/worker.js",
    "dist/app",
    "dist/http",
    "dist/lib",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:admin": "tsx src/admin.ts",
    "dev": "tsx src/index.ts",
    "dev:hosted": "tsx src/dev/hosted.ts",
    "release:check": "node scripts/release-check.mjs",
    "start:admin": "node dist/admin.js",
    "start:http": "node dist/dev/hosted.js",
    "start:worker": "node dist/worker.js",
    "start": "node bin/youtube-video-analyzer-mcp.js",
    "test": "npm run build && node dist/test/index.js"
  },
  "keywords": [
    "mcp",
    "gemini",
    "youtube",
    "video-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bullmq": "^5.71.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
