# Copy to `.env.oauth.local` (gitignored). Used when OAUTH_ENV_PROFILE=local:
#   npm run dev:hosted:oauth-local
#
# Keep production OAuth + API settings in `.env` (same as Render). Put only
# localhost-specific overrides here so you do not edit `.env` when switching.
#
# If /api/web/session returns HTTP 500 and the UI says Redis/durability: your
# `.env` may include PORT= or HOSTED_RUNTIME_ROLE= from Render, which forces
# Redis. Fix one of: run local Redis + REDIS_URL=redis://127.0.0.1:6379, or
# unset PORT / HOSTED_RUNTIME_ROLE for pure local dev, or set:
#   CLOUD_DURABILITY_MODE=allow_memory_fallback

# Allow real OAuth (disable the open local shortcut while testing sign-in)
ALLOW_UNAUTHENTICATED_HOSTED_DEV=false

# Register this exact redirect URI in your IdP (port must match HOSTED_DEV_PORT, default 3010):
#   http://127.0.0.1:3010/oauth/callback
# Use the same host you type in the browser (127.0.0.1 vs localhost matters to the IdP).
OAUTH_WEB_REDIRECT_PATH=/oauth/callback

# Optional: dev-only SPA client id if your production client does not allow localhost callbacks
# OAUTH_WEB_CLIENT_ID=your_local_spa_client_id

# Optional: if your dev tenant differs from production
# OAUTH_ISSUER=https://dev-tenant.example.com/
# OAUTH_JWKS_URL=https://dev-tenant.example.com/.well-known/jwks.json
# OAUTH_AUDIENCE=https://your-service.onrender.com/
